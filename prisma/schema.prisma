generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

// ضفنا enum لحالات الطلب عشان نتحكم في ألوان الـ Badges في الداشبورد
enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   
  role          Role      @default(USER) 
  accounts      Account[]
  sessions      Session[]
  orders        Order[]   // علاقة جديدة: المستخدم الواحد يقدر يعمل كذا طلب
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String?     @db.Text
  price       Decimal     @db.Decimal(10, 2)
  stock       Int         @default(0)
  isFeatured  Boolean     @default(false)
  isArchived  Boolean     @default(false)
  
  // ضفنا مصفوفات عشان الملابس بيكون ليها مقاسات وألوان متعددة
  sizes       String[]    @default(["S", "M", "L", "XL"])
  colors      String[]    @default([])
  
  category    Category    @relation(fields: [categoryId], references: [id])
  categoryId  String
  
  images      Image[]
  orderItems  OrderItem[] // علاقة جديدة: المنتج ممكن يظهر في كذا طلبية
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([categoryId])
}

model Image {
  id        String   @id @default(cuid())
  url       String
  order     Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  createdAt DateTime @default(now())

  @@index([productId])
}

// --- الجداول الجديدة الخاصة بالطلبيات والمبيعات ---

model Order {
  id         String      @id @default(cuid())
  status     OrderStatus @default(PENDING)
  totalPrice Decimal     @db.Decimal(10, 2)
  isPaid     Boolean     @default(false)
  phone      String      @default("")
  address    String      @default("")
  
  // ربط الطلب بالعميل (لو مسجل)
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId     String?
  
  orderItems OrderItem[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([userId])
}

model OrderItem {
  id        String   @id @default(cuid())
  quantity  Int      @default(1)
  size      String?  // المقاس اللي العميل اختاره للهودي
  color     String?  // اللون اللي العميل اختاره
  
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  productId String

  @@index([orderId])
  @@index([productId])
}

model Inquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String   @db.Text
  createdAt DateTime @default(now())
}